# ── Base de datos ──────────────────────────────────────────────────────────────
DB_PASSWORD=cambia_esto_por_algo_seguro

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=genera_con__openssl_rand_base64_32
JWT_REFRESH_SECRET=genera_con__openssl_rand_base64_32

# ── Backend (usado internamente por Docker Compose) ────────────────────────────
DATABASE_URL=postgresql://sellaplus:${DB_PASSWORD}@db:5432/sellaplus

# ── Frontend (build arg — debe apuntar al dominio real del backend) ────────────
NEXT_PUBLIC_API_URL=https://api.tudominio.com/api/v1

# ── Email (opcional) ───────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tucuenta@gmail.com
SMTP_PASS=app_password_de_gmail
SMTP_FROM=SellaPlus <tucuenta@gmail.com>
